# TaskFlow Backend Environment Configuration (CI-021)
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Server
PORT=5000
NODE_ENV=development

# JWT — Change this to a long, random string in production
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING_IN_PRODUCTION

# Database (SQLite file path, relative to backend/)
DB_PATH=./data/taskflow.db
